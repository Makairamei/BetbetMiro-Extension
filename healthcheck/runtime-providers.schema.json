{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sad25kag/BetbetMiro-Extension/healthcheck/runtime-providers.schema.json",
  "title": "BetbetMiro runtime health check config",
  "type": "object",
  "additionalProperties": false,
  "required": ["providers"],
  "properties": {
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "module": {"type": "string"},
          "enabled": {"type": "boolean", "default": true},
          "detailUrl": {"type": "string", "pattern": "^https?://"},
          "episodeUrl": {"type": "string", "pattern": "^https?://"},
          "playerUrl": {"type": "string", "pattern": "^https?://"},
          "referer": {"type": "string"},
          "origin": {"type": "string"},
          "userAgent": {"type": "string"},
          "expectedHosts": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "default": []
          },
          "expectedMediaPatterns": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "default": [".m3u8", ".mp4", "iframe", "embed", "source"]
          },
          "blockedKeywords": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "default": ["captcha", "cloudflare", "access denied", "checking your browser"]
          },
          "notes": {"type": "string"}
        },
        "anyOf": [
          {"required": ["playerUrl"]},
          {"required": ["episodeUrl"]},
          {"required": ["detailUrl"]}
        ]
      }
    }
  }
}
